{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "co.gemina/filetag",
  "title": "Gemina FileTag",
  "description": "Tag, rename, and enrich PDFs and images. Free tier: 1,500 tags/month, no credit card.",
  "version": "1.0.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/tommyil/gemina-mcp/main/assets/logo.png",
      "sizes": "400x400",
      "mimeType": "image/png"
    }
  ],
  "repository": {
    "url": "https://github.com/tommyil/gemina-mcp",
    "source": "github"
  },
  "websiteUrl": "https://www.gemina.co/filetag",
  "documentationUrl": "https://www.gemina.co/docs/filetag",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.gemina.co/api/v1/mcp/",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "Gemina API key. Get one free at https://console.gemina.co/registration/create-account",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
